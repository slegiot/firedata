    "/v1/finance/assets": {
      "get": {
        "tags": [
          "Finance"
        ],
        "description": "List supported financial assets",
        "parameters": [
          {
            "schema": {
              "type": "string"
            },
            "in": "query",
            "name": "symbol",
            "required": false,
            "description": "Filter by symbol (e.g. AAPL, BTC)"
          },
          {
            "schema": {
              "type": "string"
            },
            "in": "query",
            "name": "asset_type",
            "required": false,
            "description": "Filter by type (equity, crypto)"
          }
        ],
        "security": [
          {
            "apiKey": []
          }
        ],
        "responses": {
          "200": {
            "description": "Default Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "id": {
                            "type": "string"
                          },
                          "symbol": {
                            "type": "string"
                          },
                          "name": {
                            "type": "string"
                          },
                          "asset_type": {
                            "type": "string"
                          }
                        }
                      }
                    },
                    "meta": {
                      "type": "object",
                      "properties": {
                        "source": {
                          "type": "string"
                        },
                        "cached": {
                          "type": "boolean"
                        },
                        "fetched_at": {
                          "type": "string",
                          "format": "date-time"
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "429": {
            "description": "Rate Limit Exceeded",
            "content": {
              "application/json": {
                "schema": {
                  "description": "Rate Limit Exceeded",
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string"
                    },
                    "retry_after": {
                      "type": "number"
                    }
                  }
                }
              }
            }
          },
          "502": {
            "description": "Bad Gateway (Upstream Error)",
            "content": {
              "application/json": {
                "schema": {
                  "description": "Bad Gateway (Upstream Error)",
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string"
                    },
                    "details": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      }
