# ─── FireData · Environment Variables ──────────────────────────
#
# Copy to .env and fill in real values:
#   cp .env.example .env
#
# ────────────────────────────────────────────────────────────────

# === Postgres ===
POSTGRES_USER=firedata
POSTGRES_PASSWORD=firedata
POSTGRES_DB=firedata
POSTGRES_URL=postgres://firedata:firedata@postgres:5432/firedata

# === Redis ===
REDIS_URL=redis://redis:6379

# === Firecrawl (primary data ingestion engine) ===
FIRECRAWL_BASE_URL=http://firecrawl-api:3002
# FIRECRAWL_API_KEY=          # Only if your Firecrawl instance requires auth
# FIRECRAWL_PROXY=            # Default proxy for all Firecrawl requests

# === Service Ports ===
# api-gateway is exposed on this host port (maps to internal 3000)
API_GATEWAY_PORT=8080
API_GATEWAY_INTERNAL_PORT=3000

# Internal ports (not exposed to host, used inside Docker network)
FINANCE_SERVICE_PORT=3001
NEWS_SERVICE_PORT=3002
SPORTS_SERVICE_PORT=3003
BETTING_ODDS_SERVICE_PORT=3004

# === Scraping Targets ===
# Comma-separated URLs that workers will scrape via Firecrawl.
# These are the SOURCE sites, not third-party APIs.

# Finance: sites to scrape for quotes, fundamentals, crypto prices
FINANCE_SCRAPE_TARGETS=https://finance.yahoo.com,https://www.google.com/finance,https://coinmarketcap.com

# News: sites/RSS feeds to crawl for articles
NEWS_SCRAPE_TARGETS=https://www.bbc.co.uk/news,https://www.reuters.com,https://www.cnbc.com
NEWS_RSS_SOURCES=https://feeds.bbci.co.uk/news/rss.xml,https://rss.nytimes.com/services/xml/rss/nyt/HomePage.xml

# Sports: sites to scrape for fixtures, scores, standings
SPORTS_SCRAPE_TARGETS=https://www.espn.com,https://www.flashscore.com,https://www.sofascore.com

# Betting: sportsbook sites to scrape for odds (may need proxy)
BETTING_SCRAPE_TARGETS=https://www.bet365.com,https://www.draftkings.com,https://sportsbook.fanduel.com
# BETTING_PROXY_URL=           # Residential proxy for geo-restricted betting sites
# BETTING_PROXY_URL_RESIDENTIAL=  # Alternative residential proxy
